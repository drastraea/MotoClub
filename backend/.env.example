# Application settings now live in config.yaml (one section per environment).
# The process only needs to know which section to load and where the file is.
APP_ENV=local
CONFIG_PATH=config.yaml
TZ=Asia/Jakarta

# In production, config.yaml references ${VAR} for secrets — set them here or in
# your deploy environment, e.g.:
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
# JWT_SECRET=change-me
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# FRONTEND_ORIGIN=https://app.motoclub.example
# PORT=8080
# LOG_LEVEL=info

# For the goose CLI (make migrate-*) — separate from the app config.
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://motoclub:motoclub@localhost:5432/motoclub?sslmode=disable
