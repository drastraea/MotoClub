# Copy to .env and adjust. Consumed by the api service / local `make run`.
PORT=8080
DATABASE_URL=postgres://motoclub:motoclub@localhost:5432/motoclub?sslmode=disable
JWT_SECRET=dev-secret-change-me
GOOGLE_CLIENT_ID=dev-google-client-id.apps.googleusercontent.com
TOKEN_TTL_HOURS=24
TZ=Asia/Jakarta

# For goose CLI (make migrate-*)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://motoclub:motoclub@localhost:5432/motoclub?sslmode=disable
