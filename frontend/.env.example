# Copy to .env.local for local dev (`npm run dev`), or pass as build args for Docker.
# NEXT_PUBLIC_* values are read at BUILD time.

# Base URL of the Go backend API. Local default shown; use your prod URL in prod.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Google OAuth Client ID for Google Sign-In. Must match the backend's
# GOOGLE_CLIENT_ID and list http://localhost:3000 (and your prod origin) as an
# authorized JavaScript origin in the Google Cloud console. Leave empty to
# disable Sign-In.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
